# Copy to .env and fill in your values
# LLM access (any OpenAI-compatible endpoint)
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://api.openai.com/v1"

# Default model for prompt generation and verification
# (overridable per-step with --model)
AMBIG_LLM_MODEL=gpt-4o-mini

# Optional: separate verifier model for step_2_llm_verify.py
# AMBIG_VERIFIER_MODEL=gpt-4o

# Optional: per-call output token cap (default 16384)
# AMBIG_LLM_MAX_TOKENS=16384

# HuggingFace push token (only needed for --upload in step 3)
# HF_TOKEN=hf_...
