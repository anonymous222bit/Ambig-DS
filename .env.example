# DSBench environment template.
#
# Usage:
#   cp .env.example .env
#   $EDITOR .env                       # fill in the values below
#   set -a && source .env && set +a    # export everything into your shell
#
# Only fill in the variables you need for the pipeline you intend to run
# (see README.md "Configuration" for which step uses which variable).

# ---------------------------------------------------------------------------
# LLM access (OpenAI-compatible). Required by every pipeline that calls an
# LLM: creator rewrites, evaluator agents, clarify answerer, judge.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
# Leave OPENAI_BASE_URL unset to use api.openai.com, or point it at any
# OpenAI-compatible gateway (Azure, vLLM, marketplace, etc.).
OPENAI_BASE_URL=https://api.openai.com/v1

# Default chat model id used by creator pipelines (LLM rewrites).
AMBIG_LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# HuggingFace push token. Only needed by the upload steps:
#   create_datasets/ambig_ds_metric/pipeline/step_3_upload_to_hf.py
#   create_datasets/ambig_ds_target/pipeline_DSBench/step_5_upload_to_hf.py
# ---------------------------------------------------------------------------
HF_TOKEN=

